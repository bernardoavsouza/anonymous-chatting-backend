{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Docker Compose Dev",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "docker",
      "runtimeArgs": ["compose", "up", "--build"],
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "serverReadyAction": {
        "action": "startDebugging",
        "pattern": "Debugger listening on",
        "name": "Docker Attach"
      }
    },
    {
      "name": "Test",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "${env:HOME}/.nvm/nvm-exec",
      "runtimeArgs": ["pnpm", "test"],
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen"
    },
    {
      "name": "Test Watch",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "${env:HOME}/.nvm/nvm-exec",
      "runtimeArgs": ["pnpm", "test:watch"],
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen"
    }
  ]
}
