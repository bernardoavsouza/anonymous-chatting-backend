{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Docker Compose Dev",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "docker",
      "runtimeArgs": ["compose", "up", "--build"],
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "serverReadyAction": {
        "action": "startDebugging",
        "pattern": "Debugger listening on",
        "name": "Docker Attach"
      }
    },
    {
      "name": "Docker Attach",
      "type": "node",
      "request": "attach",
      "port": 9229,
      "address": "localhost",
      "localRoot": "${workspaceFolder}",
      "remoteRoot": "/app",
      "restart": true,
      "sourceMaps": true
    },
    {
      "name": "Test",
      "type": "node-terminal",
      "request": "launch",
      "command": "${env:HOME}/.nvm/nvm-exec pnpm test"
    },
    {
      "name": "Test Watch",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "${env:HOME}/.nvm/nvm-exec",
      "runtimeArgs": ["pnpm", "test:watch"],
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen"
    }
  ]
}
